---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Mail, MapPin } from 'lucide-react';
---

<BaseLayout title="Contact | My Portfolio" description="Get in touch with me.">
  <section class="py-16 md:py-24 max-w-5xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-start">
      
      <!-- Contact Info Section -->
      <div class="space-y-8">
        <div>
          <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4 text-slate-900 dark:text-white">Get in Touch</h1>
          <p class="text-lg text-slate-600 dark:text-slate-400">
            Have a question, a project idea, or just want to say hi? Drop me a message and I'll get back to you as soon as possible.
          </p>
        </div>

        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="h-12 w-12 rounded-full bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center text-indigo-600 dark:text-indigo-400">
              <Mail className="h-6 w-6" />
            </div>
            <div>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Email</p>
              <a href="mailto:hello@example.com" class="text-lg font-semibold text-slate-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
                hello@example.com
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="h-12 w-12 rounded-full bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center text-indigo-600 dark:text-indigo-400">
              <MapPin className="h-6 w-6" />
            </div>
            <div>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Location</p>
              <p class="text-lg font-semibold text-slate-900 dark:text-white">
                San Francisco, CA
              </p>
            </div>
          </div>
        </div>

        <div class="pt-6 border-t border-slate-200 dark:border-slate-800">
          <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-4">Connect with me</p>
          <div class="flex items-center gap-4">
            <a href="https://github.com" target="_blank" rel="noreferrer" class="h-10 w-10 rounded-full border border-slate-200 dark:border-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:border-indigo-600 hover:text-indigo-600 dark:hover:border-indigo-400 dark:hover:text-indigo-400 transition-colors">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
              </svg>
              <span class="sr-only">GitHub</span>
            </a>
            <a href="https://linkedin.com" target="_blank" rel="noreferrer" class="h-10 w-10 rounded-full border border-slate-200 dark:border-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:border-indigo-600 hover:text-indigo-600 dark:hover:border-indigo-400 dark:hover:text-indigo-400 transition-colors">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"></path>
              </svg>
              <span class="sr-only">LinkedIn</span>
            </a>
            <a href="https://twitter.com" target="_blank" rel="noreferrer" class="h-10 w-10 rounded-full border border-slate-200 dark:border-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:border-indigo-600 hover:text-indigo-600 dark:hover:border-indigo-400 dark:hover:text-indigo-400 transition-colors">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.005 4.15H5.059z"/>
              </svg>
              <span class="sr-only">X (Twitter)</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form Section -->
      <form 
        action="https://api.web3forms.com/submit" 
        method="POST" 
        class="space-y-6 bg-white/80 dark:bg-slate-900/80 backdrop-blur-sm p-8 sm:p-10 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-xl shadow-slate-200/20 dark:shadow-none"
      >
        <!-- Web3Forms Access Key -->
        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

        <div>
          <label for="name" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
            Name
          </label>
          <input 
            type="text" 
            name="name" 
            id="name" 
            required 
            class="w-full px-4 py-3 rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all placeholder:text-slate-400"
            placeholder="John Doe"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
            Email
          </label>
          <input 
            type="email" 
            name="email" 
            id="email" 
            required 
            class="w-full px-4 py-3 rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all placeholder:text-slate-400"
            placeholder="john@example.com"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
            Message
          </label>
          <textarea 
            name="message" 
            id="message" 
            rows="5" 
            required 
            class="w-full px-4 py-3 rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all resize-none placeholder:text-slate-400"
            placeholder="How can I help you?"
          ></textarea>
        </div>

        <button 
          type="submit" 
          class="w-full py-4 bg-indigo-600 text-white font-bold rounded-xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-500/30 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 active:scale-[0.98]"
        >
          Send Message
        </button>
      </form>
      
    </div>
  </section>
</BaseLayout>
