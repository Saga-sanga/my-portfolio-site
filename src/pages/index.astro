---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowRight, Code2, Rocket, Layout, Mail } from 'lucide-react';
---

<BaseLayout title="My Portfolio" description="Welcome to my developer portfolio and blog.">
  <!-- Hero Section -->
  <section class="relative pt-24 pb-16 md:pt-36 md:pb-24">
    <div class="space-y-8">
      <div class="inline-flex items-center rounded-full border border-indigo-500/30 bg-indigo-500/10 px-3 py-1 text-sm font-medium text-indigo-600 dark:text-indigo-400">
        <span class="flex h-2 w-2 rounded-full bg-indigo-600 dark:bg-indigo-400 mr-2 animate-pulse"></span>
        Available for new opportunities
      </div>
      
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
        Building digital <br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-cyan-400">
          experiences that matter.
        </span>
      </h1>
      
      <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 max-w-2xl leading-relaxed">
        I'm a Web Developer specializing in building exceptional, high-quality websites and applications using modern technologies.
      </p>
      
      <div class="flex flex-wrap gap-4 pt-4">
        <a href="/projects" class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-indigo-500/30 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-all">
          View my work
          <ArrowRight className="ml-2 h-4 w-4" />
        </a>
        <a href="/contact" class="inline-flex items-center justify-center rounded-lg border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-6 py-3 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
          Get in touch
        </a>
      </div>

      <div class="flex items-center gap-5 pt-6 text-slate-500 dark:text-slate-400">
        <a href="https://github.com" target="_blank" rel="noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
          </svg>
          <span class="sr-only">GitHub</span>
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"></path>
          </svg>
          <span class="sr-only">LinkedIn</span>
        </a>
        <a href="mailto:hello@example.com" class="hover:text-slate-900 dark:hover:text-white transition-colors">
          <Mail className="h-6 w-6" />
          <span class="sr-only">Email</span>
        </a>
      </div>
    </div>
  </section>
  
  <!-- What I Do Section -->
  <section class="py-16 md:py-24">
    <div class="flex items-center gap-4 mb-8">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">What I do</h2>
      <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
    </div>
    
    <div class="grid sm:grid-cols-3 gap-6">
      <div class="group p-6 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1">
        <div class="h-12 w-12 rounded-lg bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center mb-6 text-indigo-600 dark:text-indigo-400 group-hover:scale-110 transition-transform">
          <Code2 className="h-6 w-6" />
        </div>
        <h3 class="text-xl font-bold mb-3 text-slate-900 dark:text-white">Web Development</h3>
        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
          Building fast, responsive, and accessible websites using modern frameworks like React, Astro, and Next.js.
        </p>
      </div>

      <div class="group p-6 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1">
        <div class="h-12 w-12 rounded-lg bg-cyan-100 dark:bg-cyan-900/30 flex items-center justify-center mb-6 text-cyan-600 dark:text-cyan-400 group-hover:scale-110 transition-transform">
          <Layout className="h-6 w-6" />
        </div>
        <h3 class="text-xl font-bold mb-3 text-slate-900 dark:text-white">UI/UX Design</h3>
        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
          Creating intuitive user interfaces and delightful experiences with a focus on usability and aesthetics.
        </p>
      </div>

      <div class="group p-6 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1">
        <div class="h-12 w-12 rounded-lg bg-fuchsia-100 dark:bg-fuchsia-900/30 flex items-center justify-center mb-6 text-fuchsia-600 dark:text-fuchsia-400 group-hover:scale-110 transition-transform">
          <Rocket className="h-6 w-6" />
        </div>
        <h3 class="text-xl font-bold mb-3 text-slate-900 dark:text-white">Performance</h3>
        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
          Optimizing web applications for maximum speed and scale, ensuring the best possible user experience.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="py-16 md:py-24">
    <div class="flex items-center gap-4 mb-8">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Featured Projects</h2>
      <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
    </div>
    
    <div class="grid sm:grid-cols-2 gap-6">
      
      <div class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:shadow-xl transition-all">
        <div class="aspect-video w-full bg-slate-100 dark:bg-slate-800 overflow-hidden">
          <!-- Placeholder for project image -->
          <div class="w-full h-full flex items-center justify-center text-slate-400">
            <Layout className="w-12 h-12 opacity-50" />
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">E-commerce Dashboard</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm">A high-performance dashboard for managing online stores, featuring real-time analytics and inventory management.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">React</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">TypeScript</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">Tailwind</span>
          </div>
        </div>
      </div>
      
      <div class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:shadow-xl transition-all">
        <div class="aspect-video w-full bg-slate-100 dark:bg-slate-800 overflow-hidden">
          <!-- Placeholder for project image -->
          <div class="w-full h-full flex items-center justify-center text-slate-400">
            <Layout className="w-12 h-12 opacity-50" />
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Astro Portfolio</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm">A blazingly fast portfolio and blog built with Astro's island architecture and styled with Tailwind CSS.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">Astro</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">MDX</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">Tailwind</span>
          </div>
        </div>
      </div>
      
    </div>
  </section>
</BaseLayout>