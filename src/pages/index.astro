---
import "../styles/global.css"
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowRight, Code2, Rocket, Layout, Mail, Palette, Zap, Globe, Award, Coffee, MapPin, ArrowDown } from 'lucide-react';
---

<BaseLayout title="My Portfolio" description="Welcome to my developer portfolio and blog.">
  <!-- Hero Section -->
  <section class="relative min-h-screen flex flex-col justify-center pt-24 pb-16 md:pt-36 md:pb-24">
    <div class="absolute inset-0 -z-10 w-[100vw] left-1/2 -translate-x-1/2 pointer-events-none">
      <div class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#e2e8f0_1px,transparent_1px),linear-gradient(to_bottom,#e2e8f0_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
    </div>
    <div class="space-y-8">
      <div class="inline-flex items-center rounded-full border border-indigo-500/30 bg-indigo-500/10 px-3 py-1 text-sm font-medium text-indigo-600 dark:text-indigo-400">
        <span class="relative flex h-3 w-3 mr-2 justify-center items-center">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
          <span class="relative rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        Open to collaborations
      </div>
      
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
        Hi, I'm <br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-cyan-400">
          Reckson Khiangte
        </span>
      </h1>
      
      <p class="text-2xl md:text-3xl text-slate-700 dark:text-slate-300 max-w-2xl leading-relaxed font-semibold">
        Web Developer | 🚀 🏋🏽‍♂️
      </p>

      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl leading-relaxed">
        A passionate developer from Mizoram, India. I love building modern web applications with TypeScript, React, and SolidJS. Always learning, always shipping.
      </p>
      
      <div class="flex flex-wrap gap-4 pt-4">
        <a href="/projects" class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-indigo-500/30 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-all">
          View my work
          <ArrowRight className="ml-2 h-4 w-4" />
        </a>
        <a href="/contact" class="inline-flex items-center justify-center rounded-lg border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-6 py-3 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
          Get in touch
        </a>
      </div>

      <div class="flex items-center gap-5 pt-6 text-slate-500 dark:text-slate-400">
        <a href="https://github.com/Saga-sanga" target="_blank" rel="noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
          </svg>
          <span class="sr-only">GitHub</span>
        </a>
        <a href="https://twitter.com/RecksonKhiangte" target="_blank" rel="noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"></path>
          </svg>
          <span class="sr-only">Twitter</span>
        </a>
        <a href="mailto:recksonk94@gmail.com" class="hover:text-slate-900 dark:hover:text-white transition-colors">
          <Mail className="h-6 w-6" />
          <span class="sr-only">Email</span>
        </a>
      </div>

      <!-- Scroll Indicator -->
      <a
        href="#about"
        class="absolute bottom-8 left-1/2 -translate-x-1/2 p-2 rounded-full bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors animate-bounce"
        aria-label="Scroll to about section"
      >
        <ArrowDown className="w-5 h-5 text-slate-500 dark:text-slate-400" />
      </a>
    </div>
  </section>
  
  <!-- About Me Section -->
  <section class="py-16 md:py-24" id="about">
    <div class="flex items-center gap-4 mb-8">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">About Me</h2>
      <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image/Visual Side -->
      <div class="relative">
        <div class="relative aspect-square max-w-md mx-auto lg:mx-0">
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-indigo-500/10 rounded-2xl -z-10"></div>
          <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-slate-100 dark:bg-slate-800 rounded-2xl -z-10"></div>

          <div class="w-full h-full rounded-2xl overflow-hidden bg-gradient-to-br from-slate-100 to-slate-50 dark:from-slate-800 dark:to-slate-800/50 border border-slate-200 dark:border-slate-700">
            <div class="w-full h-full flex items-center justify-center">
              <div class="text-center p-8">
                <div class="w-32 h-32 mx-auto mb-6 rounded-full bg-gradient-to-br from-indigo-500 to-indigo-500/70 flex items-center justify-center">
                  <Code2 className="w-16 h-16 text-white" />
                </div>
                <p class="text-lg font-semibold text-slate-900 dark:text-white">Reckson Khiangte</p>
                <p class="text-slate-600 dark:text-slate-400">Web Developer</p>
                <div class="flex items-center justify-center gap-2 mt-3 text-sm text-slate-500 dark:text-slate-400">
                  <MapPin className="w-4 h-4" />
                  <span>Mizoram, India</span>
                </div>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-6 -right-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-4 shadow-lg">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center">
                <Zap className="w-5 h-5 text-emerald-500" />
              </div>
              <div>
                <p class="text-sm font-medium text-slate-900 dark:text-white">EddieHub Member</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">Open Source Contributor</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Side -->
      <div class="space-y-6">
        <div class="space-y-4">
          <h3 class="text-2xl font-bold text-slate-900 dark:text-white">
            Building the web, one commit at a time
          </h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Hey there! I'm Reckson Zirsangzela Khiangte, a web developer from 
            Mizoram, India. I'm passionate about building modern web applications 
            and contributing to open source projects.
          </p>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            I specialize in TypeScript, React, and SolidJS. I enjoy working with 
            modern frameworks like Next.js and exploring new technologies. When I'm 
            not coding, you'll find me at the gym 🏋🏽‍♂️ or exploring new tech.
          </p>
        </div>

        <!-- Skills Tags -->
        <div class="flex flex-wrap gap-2">
          {['TypeScript', 'React', 'SolidJS', 'Next.js', 'Node.js', 'Payload CMS'].map(
            (skill) => (
              <span class="px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm font-medium">
                {skill}
              </span>
            )
          )}
        </div>

        <!-- What I Do -->
        <div class="grid sm:grid-cols-2 gap-4 pt-4">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center flex-shrink-0">
              <Code2 className="w-5 h-5 text-indigo-600 dark:text-indigo-400" />
            </div>
            <div>
              <h4 class="font-semibold mb-1 text-slate-900 dark:text-white">Web Development</h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Building full-stack applications with modern tech
              </p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center flex-shrink-0">
              <Palette className="w-5 h-5 text-indigo-600 dark:text-indigo-400" />
            </div>
            <div>
              <h4 class="font-semibold mb-1 text-slate-900 dark:text-white">Open Source</h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Contributing to community projects
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-20">
      {[
        { icon: Code2, value: '87+', label: 'Repositories' },
        { icon: Coffee, value: '1000+', label: 'Cups of Coffee' },
        { icon: Award, value: '3', label: 'GitHub Achievements' },
        { icon: Globe, value: '20+', label: 'Followers' },
      ].map((stat) => (
        <div class="text-center p-6 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50">
          <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-indigo-500/10 flex items-center justify-center">
            <stat.icon className="w-6 h-6 text-indigo-600 dark:text-indigo-400" />
          </div>
          <div class="text-3xl font-bold mb-1 text-slate-900 dark:text-white">
            {stat.value}
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="py-16 md:py-24">
    <div class="flex items-center gap-4 mb-8">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Featured Projects</h2>
      <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
    </div>
    
    <div class="grid sm:grid-cols-2 gap-6 mb-10">
      
      <a href="https://github.com/Saga-sanga/tangka-t3" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:shadow-xl transition-all hover:-translate-y-1 block">
        <div class="aspect-video w-full bg-slate-100 dark:bg-slate-800 overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500/10 to-cyan-400/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-full h-full flex items-center justify-center text-slate-400 group-hover:text-indigo-500 transition-colors">
            <Layout className="w-12 h-12 opacity-50 group-hover:scale-110 transition-transform" />
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Tangka T3</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">A web based POS system targeted at small and medium businesses.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">TypeScript</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">T3 Stack</span>
          </div>
        </div>
      </a>
      
      <a href="https://github.com/Saga-sanga/mizo-apologia" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:shadow-xl transition-all hover:-translate-y-1 block">
        <div class="aspect-video w-full bg-slate-100 dark:bg-slate-800 overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500/10 to-fuchsia-400/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-full h-full flex items-center justify-center text-slate-400 group-hover:text-indigo-500 transition-colors">
            <Layout className="w-12 h-12 opacity-50 group-hover:scale-110 transition-transform" />
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Mizo Apologia</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">Mizo Apologia frontend. A bible question and answer site.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">JavaScript</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">React</span>
          </div>
        </div>
      </a>
      
    </div>

    <div class="flex justify-center mt-8">
      <a href="/projects" class="inline-flex items-center justify-center rounded-lg border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-6 py-3 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all hover:text-indigo-600 dark:hover:text-indigo-400">
        View all projects
        <ArrowRight className="ml-2 h-4 w-4" />
      </a>
    </div>
  </section>
</BaseLayout>
