---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { format } from 'date-fns';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog | My Portfolio" description="My thoughts and tutorials on web development.">
  <section class="py-12">
    <h1 class="text-4xl font-extrabold tracking-tight mb-8 text-slate-900 dark:text-white">Blog</h1>
    
    <div class="space-y-12">
      {posts.map((post) => (
        <article class="group relative flex flex-col items-start justify-between p-6 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1">
          <div class="flex items-center gap-x-4 text-xs mb-4">
            <time datetime={post.data.pubDate.toISOString()} class="text-slate-500 dark:text-slate-400 font-medium">
              {format(post.data.pubDate, 'MMMM d, yyyy')}
            </time>
            {post.data.tags && post.data.tags.length > 0 && (
              <span class="relative z-10 rounded-full bg-indigo-50 dark:bg-indigo-500/10 px-3 py-1.5 font-medium text-indigo-600 dark:text-indigo-400">
                {post.data.tags[0]}
              </span>
            )}
          </div>
          <div class="group relative">
            <h3 class="mt-3 text-2xl font-bold leading-6 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
              <a href={`/blog/${post.id}`}>
                <span class="absolute inset-0"></span>
                {post.data.title}
              </a>
            </h3>
            <p class="mt-5 line-clamp-3 text-sm leading-6 text-slate-600 dark:text-slate-400">
              {post.data.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
