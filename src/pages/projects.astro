---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Layout, Smartphone, Database, Globe, Cpu, Server, GitPullRequest, Code2, Bitcoin } from 'lucide-react';
---

<BaseLayout title="Projects | My Portfolio" description="A collection of my recent web development projects and contributions.">
  <section class="pt-24 pb-16 md:pt-32 md:pb-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4 text-slate-900 dark:text-white">My Projects</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        A showcase of my recent work, open-source contributions, frontend challenges, and experiments. 
        Each project represents a unique challenge and learning experience.
      </p>
    </div>

    <!-- Category: Featured Work -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="p-2 rounded-lg bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400">
          <Layout className="w-5 h-5" />
        </div>
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Featured Work</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800 ml-4"></div>
      </div>
      
      <div class="grid sm:grid-cols-2 gap-6">
        <a href="https://github.com/Saga-sanga/tangka-t3" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1 p-6 block">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Tangka T3</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">A web based POS system targeted at small and medium businesses.</p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">TypeScript</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">T3 Stack</span>
          </div>
        </a>

        <a href="https://github.com/Saga-sanga/mizo-apologia" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1 p-6 block">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Mizo Apologia</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">Mizo Apologia frontend. A bible question and answer site.</p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">JavaScript</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">React</span>
          </div>
        </a>
        
        <a href="https://github.com/Saga-sanga/todo-trpc" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1 p-6 block">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Todo TRPC</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">An highly interactive todo app built on next app router and trpc.</p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">TypeScript</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">Next.js</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">tRPC</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Category: Open Source Contributions -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="p-2 rounded-lg bg-cyan-100 dark:bg-cyan-900/30 text-cyan-600 dark:text-cyan-400">
          <GitPullRequest className="w-5 h-5" />
        </div>
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Open Source Contributions</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800 ml-4"></div>
      </div>
      
      <div class="grid sm:grid-cols-2 gap-6">
        <a href="https://github.com/calcom/cal.com" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1 p-6 block">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-cyan-600 dark:group-hover:text-cyan-400 transition-colors">Cal.com</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">Scheduling infrastructure for absolutely everyone.</p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">TypeScript</span>
          </div>
        </a>

        <a href="https://github.com/dubinc/dub" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1 p-6 block">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-cyan-600 dark:group-hover:text-cyan-400 transition-colors">Dub.co</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">An open-source link shortener with built-in analytics + free custom domains.</p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">TypeScript</span>
          </div>
        </a>

        <a href="https://github.com/formbricks/formbricks" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1 p-6 block">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-cyan-600 dark:group-hover:text-cyan-400 transition-colors">Formbricks</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">Open Source Surveys & Experience Management Solution.</p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">TypeScript</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Category: Frontend Challenges -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="p-2 rounded-lg bg-fuchsia-100 dark:bg-fuchsia-900/30 text-fuchsia-600 dark:text-fuchsia-400">
          <Code2 className="w-5 h-5" />
        </div>
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Frontend Challenges</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800 ml-4"></div>
      </div>
      
      <div class="grid sm:grid-cols-2 gap-6">
        <a href="https://github.com/Saga-sanga/interactive-card" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1 p-6 block">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-fuchsia-600 dark:group-hover:text-fuchsia-400 transition-colors">Interactive Card Form</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">FrontEnd Mentor design challenge to create an interactive credit card input form with form validation.</p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">JavaScript</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">CSS</span>
          </div>
        </a>

        <a href="https://github.com/Saga-sanga/Manage-landing-page" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:shadow-xl hover:-translate-y-1 p-6 block">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-fuchsia-600 dark:group-hover:text-fuchsia-400 transition-colors">Manage Landing Page</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">Manage Landing Page design challenge from FrontEnd Mentors.</p>
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">TypeScript</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Category: Experiments & Web3 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-8">
        <div class="p-2 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400">
          <Bitcoin className="w-5 h-5" />
        </div>
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Experiments & Web3</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800 ml-4"></div>
      </div>
      
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        <a href="https://github.com/Saga-sanga/gowithtests" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:-translate-y-1 p-6 block">
          <h3 class="text-lg font-bold mb-2 text-slate-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">Go with Tests</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-4 text-xs line-clamp-2">My golang learning code repository.</p>
          <div class="flex gap-2">
            <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-[10px] rounded font-medium text-slate-600 dark:text-slate-300">Go</span>
          </div>
        </a>

        <a href="https://github.com/Saga-sanga/alchemy-block-explorer" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:-translate-y-1 p-6 block">
          <h3 class="text-lg font-bold mb-2 text-slate-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">Block Explorer</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-4 text-xs line-clamp-2">Alchemy University assignment: an Ethereum block explorer.</p>
          <div class="flex gap-2">
            <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-[10px] rounded font-medium text-slate-600 dark:text-slate-300">JavaScript</span>
            <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-[10px] rounded font-medium text-slate-600 dark:text-slate-300">Web3</span>
          </div>
        </a>

        <a href="https://github.com/Saga-sanga/asteroids-py" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:bg-white dark:hover:bg-slate-900 transition-all hover:-translate-y-1 p-6 block">
          <h3 class="text-lg font-bold mb-2 text-slate-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">Asteroids Python</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-4 text-xs line-clamp-2">Asteroids game clone built in Python.</p>
          <div class="flex gap-2">
            <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-[10px] rounded font-medium text-slate-600 dark:text-slate-300">Python</span>
          </div>
        </a>
      </div>
    </div>

  </section>
</BaseLayout>
