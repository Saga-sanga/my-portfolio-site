---
import { ArrowRight, Layout } from "lucide-react";
---

<section class="py-16 md:py-24">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <span class="inline-block px-4 py-1.5 rounded-full bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 text-sm font-medium mb-4">
          Portfolio
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-slate-900 dark:text-white">
          Featured Projects
        </h2>
      </div>
    </div>
    
    <div class="grid sm:grid-cols-2 gap-6 mb-10">
      
      <a href="https://github.com/Saga-sanga/tangka-t3" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:shadow-xl transition-all hover:-translate-y-1 block">
        <div class="aspect-video w-full bg-slate-100 dark:bg-slate-800 overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500/10 to-cyan-400/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-full h-full flex items-center justify-center text-slate-400 group-hover:text-indigo-500 transition-colors">
            <Layout className="w-12 h-12 opacity-50 group-hover:scale-110 transition-transform" />
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Tangka T3</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">A web based POS system targeted at small and medium businesses.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">TypeScript</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">T3 Stack</span>
          </div>
        </div>
      </a>
      
      <a href="https://github.com/Saga-sanga/mizo-apologia" target="_blank" rel="noreferrer" class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:shadow-xl transition-all hover:-translate-y-1 block">
        <div class="aspect-video w-full bg-slate-100 dark:bg-slate-800 overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500/10 to-fuchsia-400/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-full h-full flex items-center justify-center text-slate-400 group-hover:text-indigo-500 transition-colors">
            <Layout className="w-12 h-12 opacity-50 group-hover:scale-110 transition-transform" />
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Mizo Apologia</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm line-clamp-2">Mizo Apologia frontend. A bible question and answer site.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">JavaScript</span>
            <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs rounded-md font-medium text-slate-600 dark:text-slate-300">React</span>
          </div>
        </div>
      </a>
      
    </div>

      <div class="flex justify-center mt-8">
        <a href="/projects" class="inline-flex items-center justify-center rounded-lg border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-6 py-3 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all hover:text-indigo-600 dark:hover:text-indigo-400">
          View all projects
          <ArrowRight className="ml-2 h-4 w-4" />
        </a>
      </div>
    </div>
  </section>
