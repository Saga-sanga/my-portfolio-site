---
import Stats from "../components/react/Stats.tsx";
import TechStack from "../components/astro/TechStack.astro";
import { Code2, MapPin, Palette, Zap } from "lucide-react";
---

<section class="py-16 md:py-24" id="about">
  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <span
        class="mb-4 inline-block rounded-full bg-indigo-500/10 px-4 py-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400"
      >
        About Me
      </span>
      <h2
        class="mb-6 text-3xl font-bold text-slate-900 sm:text-4xl md:text-5xl dark:text-white"
      >
        Passionate about creating
        <br />
        <span class="text-slate-600 dark:text-slate-400"
          >digital experiences</span
        >
      </h2>
    </div>

    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Image/Visual Side -->
      <div class="relative">
        <div class="relative mx-auto aspect-square max-w-md lg:mx-0">
          <div
            class="absolute -top-4 -left-4 -z-10 h-24 w-24 rounded-2xl bg-indigo-500/10"
          >
          </div>
          <div
            class="absolute -right-4 -bottom-4 -z-10 h-32 w-32 rounded-2xl bg-slate-100 dark:bg-slate-800"
          >
          </div>

          <div
            class="h-full w-full overflow-hidden rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-100 to-slate-50 dark:border-slate-700 dark:from-slate-800 dark:to-slate-800/50"
          >
            <div class="flex h-full w-full items-center justify-center">
              <div class="p-8 text-center">
                <div
                  class="mx-auto mb-6 flex h-32 w-32 items-center justify-center rounded-full bg-gradient-to-br from-indigo-500 to-indigo-500/70"
                >
                  <Code2 className="h-16 w-16 text-white" />
                </div>
                <p class="text-lg font-semibold text-slate-900 dark:text-white">
                  Reckson Khiangte
                </p>
                <p class="text-slate-600 dark:text-slate-400">Web Developer</p>
                <div
                  class="mt-3 flex items-center justify-center gap-2 text-sm text-slate-500 dark:text-slate-400"
                >
                  <MapPin className="h-4 w-4" />
                  <span>Aizawl, India</span>
                </div>
              </div>
            </div>
          </div>

          <div
            class="absolute -right-6 -bottom-6 rounded-xl border border-slate-200 bg-white p-4 shadow-lg dark:border-slate-800 dark:bg-slate-900"
          >
            <div class="flex items-center gap-3">
              <div
                class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/10"
              >
                <Zap className="h-5 w-5 text-emerald-500" />
              </div>
              <div>
                <p class="text-sm font-medium text-slate-900 dark:text-white">
                  EddieHub Member
                </p>
                <p class="text-xs text-slate-500 dark:text-slate-400">
                  Open Source Contributor
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Side -->
      <div class="space-y-6">
        <div class="space-y-4">
          <h3 class="text-2xl font-bold text-slate-900 dark:text-white">
            Building the web, one commit at a time
          </h3>
          <p class="leading-relaxed text-slate-600 dark:text-slate-400">
            Hey there! I'm Reckson Zirsangzela Khiangte, a web developer from
            Aizawl, India. I'm passionate about building modern web applications
            and contributing to open source projects.
          </p>
          <p class="leading-relaxed text-slate-600 dark:text-slate-400">
            I specialize in TypeScript, React, and Astro. I enjoy working with
            modern frameworks like Next.js and exploring new technologies. When
            I'm not coding, you'll find me at the gym 🏋🏽‍♂️ or exploring new tech.
          </p>
        </div>

        <!-- Skills Tags -->
        <div class="flex flex-wrap gap-2">
          {
            [
              "TypeScript",
              "React",
              "Astro",
              "Next.js",
              "Node.js",
              "Drizzle",
            ].map((skill) => (
              <span class="rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                {skill}
              </span>
            ))
          }
        </div>

        <!-- What I Do -->
        <div class="grid gap-4 pt-4 sm:grid-cols-2">
          <div class="flex items-start gap-3">
            <div
              class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-indigo-500/10"
            >
              <Code2 className="h-5 w-5 text-indigo-600 dark:text-indigo-400" />
            </div>
            <div>
              <h4 class="mb-1 font-semibold text-slate-900 dark:text-white">
                Web Development
              </h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Building full-stack applications with modern tech
              </p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div
              class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-indigo-500/10"
            >
              <Palette
                className="h-5 w-5 text-indigo-600 dark:text-indigo-400"
              />
            </div>
            <div>
              <h4 class="mb-1 font-semibold text-slate-900 dark:text-white">
                Open Source
              </h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Contributing to community projects
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <Stats client:visible />
    <TechStack />
  </div>
</section>
