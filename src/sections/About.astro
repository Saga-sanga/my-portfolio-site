---
import Stats from "../components/react/Stats.tsx"
import { Code2, MapPin, Palette, Zap } from "lucide-react";
---

<section class="py-16 md:py-24" id="about">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 rounded-full bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 text-sm font-medium mb-4">
        About Me
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6 text-slate-900 dark:text-white">
        Passionate about creating
        <br />
        <span class="text-slate-600 dark:text-slate-400">digital experiences</span>
      </h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image/Visual Side -->
      <div class="relative">
        <div class="relative aspect-square max-w-md mx-auto lg:mx-0">
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-indigo-500/10 rounded-2xl -z-10"></div>
          <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-slate-100 dark:bg-slate-800 rounded-2xl -z-10"></div>

          <div class="w-full h-full rounded-2xl overflow-hidden bg-gradient-to-br from-slate-100 to-slate-50 dark:from-slate-800 dark:to-slate-800/50 border border-slate-200 dark:border-slate-700">
            <div class="w-full h-full flex items-center justify-center">
              <div class="text-center p-8">
                <div class="w-32 h-32 mx-auto mb-6 rounded-full bg-gradient-to-br from-indigo-500 to-indigo-500/70 flex items-center justify-center">
                  <Code2 className="w-16 h-16 text-white" />
                </div>
                <p class="text-lg font-semibold text-slate-900 dark:text-white">Reckson Khiangte</p>
                <p class="text-slate-600 dark:text-slate-400">Web Developer</p>
                <div class="flex items-center justify-center gap-2 mt-3 text-sm text-slate-500 dark:text-slate-400">
                  <MapPin className="w-4 h-4" />
                  <span>Aizawl, India</span>
                </div>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-6 -right-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-4 shadow-lg">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center">
                <Zap className="w-5 h-5 text-emerald-500" />
              </div>
              <div>
                <p class="text-sm font-medium text-slate-900 dark:text-white">EddieHub Member</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">Open Source Contributor</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Side -->
      <div class="space-y-6">
        <div class="space-y-4">
          <h3 class="text-2xl font-bold text-slate-900 dark:text-white">
            Building the web, one commit at a time
          </h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Hey there! I'm Reckson Zirsangzela Khiangte, a web developer from 
            Mizoram, India. I'm passionate about building modern web applications 
            and contributing to open source projects.
          </p>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            I specialize in TypeScript, React, and SolidJS. I enjoy working with 
            modern frameworks like Next.js and exploring new technologies. When I'm 
            not coding, you'll find me at the gym 🏋🏽‍♂️ or exploring new tech.
          </p>
        </div>

        <!-- Skills Tags -->
        <div class="flex flex-wrap gap-2">
          {['TypeScript', 'React', 'SolidJS', 'Next.js', 'Node.js', 'Payload CMS'].map(
            (skill) => (
              <span class="px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm font-medium">
                {skill}
              </span>
            )
          )}
        </div>

        <!-- What I Do -->
        <div class="grid sm:grid-cols-2 gap-4 pt-4">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center flex-shrink-0">
              <Code2 className="w-5 h-5 text-indigo-600 dark:text-indigo-400" />
            </div>
            <div>
              <h4 class="font-semibold mb-1 text-slate-900 dark:text-white">Web Development</h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Building full-stack applications with modern tech
              </p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center flex-shrink-0">
              <Palette className="w-5 h-5 text-indigo-600 dark:text-indigo-400" />
            </div>
            <div>
              <h4 class="font-semibold mb-1 text-slate-900 dark:text-white">Open Source</h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Contributing to community projects
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <Stats client:visible/>
    </div>
  </section>
