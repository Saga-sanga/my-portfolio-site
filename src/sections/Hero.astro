---
import { ArrowDown, ArrowRight, Mail } from "lucide-react";
---

<section class="relative flex min-h-screen flex-col justify-center py-32">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute top-0 right-0 bottom-0 left-0 bg-[linear-gradient(to_right,#e2e8f0_1px,transparent_1px),linear-gradient(to_bottom,#e2e8f0_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] bg-[size:14px_24px] dark:bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)]"
    >
    </div>
  </div>
  <div
    class="mx-auto flex w-full max-w-7xl flex-col items-center px-4 text-center sm:px-6 lg:px-8"
  >
    <div class="space-y-8">
      <div
        class="inline-flex items-center rounded-full border border-indigo-500/30 bg-indigo-500/10 px-3 py-1 text-sm font-medium text-indigo-600 dark:text-indigo-400"
      >
        <span class="relative mr-2 flex h-3 w-3 items-center justify-center">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"
          ></span>
          <span class="relative h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        Open to collaborations
      </div>

      <h1
        class="text-5xl leading-[1.1] font-extrabold tracking-tight text-slate-900 md:text-7xl dark:text-white"
      >
        Hi, I'm <br class="hidden md:block" />
        <span
          class="bg-gradient-to-r from-indigo-500 to-cyan-400 bg-clip-text text-transparent"
        >
          Reckson Khiangte
        </span>
      </h1>

      <p
        class="max-w-2xl text-2xl leading-relaxed font-semibold text-slate-700 md:text-3xl dark:text-slate-300"
      >
        Web Developer | 🚀 🏋🏽‍♂️
      </p>

      <p
        class="max-w-2xl text-xl leading-relaxed text-slate-600 dark:text-slate-400"
      >
        A passionate developer from Aizawl, India. I love building modern web
        applications with TypeScript, React, and NextJS. Always learning, always
        shipping.
      </p>

      <div
        class="flex flex-col items-center justify-center gap-4 pt-4 sm:flex-row"
      >
        <a
          href="/projects"
          class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-indigo-500/30 transition-all hover:bg-indigo-700 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:outline-none"
        >
          View my work
          <ArrowRight className="ml-2 h-4 w-4" />
        </a>
        <a
          href="#contact"
          class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-6 py-3 text-sm font-medium text-slate-700 transition-all hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:bg-slate-800"
        >
          Get in touch
        </a>
      </div>

      <div
        class="flex items-center justify-center gap-5 pt-6 text-slate-500 dark:text-slate-400"
      >
        <a
          href="https://github.com/Saga-sanga"
          target="_blank"
          rel="noreferrer"
          class="transition-colors hover:text-slate-900 dark:hover:text-white"
        >
          <svg
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
          <span class="sr-only">GitHub</span>
        </a>
        <a
          href="https://twitter.com/RecksonKhiangte"
          target="_blank"
          rel="noreferrer"
          class="transition-colors hover:text-slate-900 dark:hover:text-white"
        >
          <svg
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.005 4.15H5.059z"
            ></path>
          </svg>
          <span class="sr-only">X (Twitter)</span>
        </a>
        <a
          href="https://linkedin.com/RecksonKhiangte"
          target="_blank"
          rel="noreferrer"
          class="transition-colors hover:text-slate-900 dark:hover:text-white"
        >
          <svg
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              clip-rule="evenodd"></path>
          </svg>
          <span class="sr-only">LinkedIn</span>
        </a>
        <a
          href="mailto:recksonk94@gmail.com"
          class="transition-colors hover:text-slate-900 dark:hover:text-white"
        >
          <Mail className="h-6 w-6" />
          <span class="sr-only">Email</span>
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <a
      href="#about"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce rounded-full bg-slate-100 p-2 transition-colors hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700"
      aria-label="Scroll to about section"
    >
      <ArrowDown className="h-5 w-5 text-slate-500 dark:text-slate-400" />
    </a>
  </div>
</section>
