---
import { ArrowDown, ArrowRight, Mail } from "lucide-react";

---

<section class="relative min-h-screen flex flex-col justify-center pt-24 pb-16 md:pt-36 md:pb-24">
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#e2e8f0_1px,transparent_1px),linear-gradient(to_bottom,#e2e8f0_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
    </div>
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8">
      <div class="inline-flex items-center rounded-full border border-indigo-500/30 bg-indigo-500/10 px-3 py-1 text-sm font-medium text-indigo-600 dark:text-indigo-400">
        <span class="relative flex h-3 w-3 mr-2 justify-center items-center">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
          <span class="relative rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        Open to collaborations
      </div>
      
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
        Hi, I'm <br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-cyan-400">
          Reckson Khiangte
        </span>
      </h1>
      
      <p class="text-2xl md:text-3xl text-slate-700 dark:text-slate-300 max-w-2xl leading-relaxed font-semibold">
        Web Developer | 🚀 🏋🏽‍♂️
      </p>

      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl leading-relaxed">
        A passionate developer from Aizawl, India. I love building modern web applications with TypeScript, React, and NextJS. Always learning, always shipping.
      </p>
      
      <div class="flex flex-wrap gap-4 pt-4">
        <a href="/projects" class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-indigo-500/30 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-all">
          View my work
          <ArrowRight className="ml-2 h-4 w-4" />
        </a>
        <a href="/contact" class="inline-flex items-center justify-center rounded-lg border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-6 py-3 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
          Get in touch
        </a>
      </div>

      <div class="flex items-center gap-5 pt-6 text-slate-500 dark:text-slate-400">
        <a href="https://github.com/Saga-sanga" target="_blank" rel="noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
          </svg>
          <span class="sr-only">GitHub</span>
        </a>
        <a href="https://twitter.com/RecksonKhiangte" target="_blank" rel="noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"></path>
          </svg>
          <span class="sr-only">Twitter</span>
        </a>
        <a href="mailto:recksonk94@gmail.com" class="hover:text-slate-900 dark:hover:text-white transition-colors">
          <Mail className="h-6 w-6" />
          <span class="sr-only">Email</span>
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
      <a
        href="#about"
        class="absolute bottom-8 left-1/2 -translate-x-1/2 p-2 rounded-full bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors animate-bounce"
        aria-label="Scroll to about section"
      >
        <ArrowDown className="w-5 h-5 text-slate-500 dark:text-slate-400" />
      </a>
    </div>
  </section>

