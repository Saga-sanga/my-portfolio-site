---
import { Coffee, Mail, MapPin, Send } from "lucide-react";

const contactInfo = [
  {
    icon: Mail,
    label: "Email",
    value: "recksonk94@gmail.com",
    href: "mailto:recksonk94@gmail.com",
  },
  {
    icon: MapPin,
    label: "Location",
    value: "Aizawl, India",
    href: "#",
  },
  {
    icon: Coffee,
    label: "Support",
    value: "Buy me a coffee",
    href: "https://buymeacoffee.com/recksonk94k",
  },
];
---

<section
  class="mx-auto max-w-7xl px-4 pt-24 pb-16 sm:px-6 md:pt-32 md:pb-24 lg:px-8"
  id="contact"
>
  <div class="mb-16 text-center">
    <span
      class="mb-4 inline-block rounded-full bg-indigo-500/10 px-4 py-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400"
    >
      Contact
    </span>
    <h1
      class="mb-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl dark:text-white"
    >
      Get in Touch
    </h1>
    <p class="mx-auto max-w-2xl text-lg text-slate-600 dark:text-slate-400">
      Have a question, a project idea, or just want to say hi? Drop me a message
      and I'll get back to you as soon as possible.
    </p>
  </div>
  <div class="grid items-start gap-12 lg:grid-cols-5 lg:gap-16">
    <!-- Contact Info Section -->
    <div class="space-y-8 lg:col-span-2">
      <div class="space-y-6">
        {
          contactInfo.map((item) => (
            <a href={item.href} class="group flex items-start gap-4">
              <div class="bg-card group-hover:border-primary/30 group-hover:bg-primary/5 flex h-12 w-12 items-center justify-center rounded-xl border border-slate-200 transition-all dark:border-slate-800">
                <item.icon className="w-5 h-5 text-slate-600 dark:text-slate-400 group-hover:text-primary transition-colors" />
              </div>
              <div>
                <p class="mb-1 text-sm text-slate-600 dark:text-slate-400">
                  {item.label}
                </p>
                <p class="group-hover:text-primary font-medium transition-colors">
                  {item.value}
                </p>
              </div>
            </a>
          ))
        }
      </div>

      <div class="border-t border-slate-200 pt-6 dark:border-slate-800">
        <p class="mb-4 text-sm font-medium text-slate-500 dark:text-slate-400">
          Connect with me
        </p>
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/Saga-sanga"
            target="_blank"
            rel="noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-600 transition-colors hover:border-indigo-600 hover:text-indigo-600 dark:border-slate-800 dark:text-slate-400 dark:hover:border-indigo-400 dark:hover:text-indigo-400"
          >
            <svg
              class="h-5 w-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"></path>
            </svg>
            <span class="sr-only">GitHub</span>
          </a>
          <a
            href="https://linkedin.com"
            target="_blank"
            rel="noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-600 transition-colors hover:border-indigo-600 hover:text-indigo-600 dark:border-slate-800 dark:text-slate-400 dark:hover:border-indigo-400 dark:hover:text-indigo-400"
          >
            <svg
              class="h-5 w-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                clip-rule="evenodd"></path>
            </svg>
            <span class="sr-only">LinkedIn</span>
          </a>
          <a
            href="https://twitter.com/RecksonKhiangte"
            target="_blank"
            rel="noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-600 transition-colors hover:border-indigo-600 hover:text-indigo-600 dark:border-slate-800 dark:text-slate-400 dark:hover:border-indigo-400 dark:hover:text-indigo-400"
          >
            <svg
              class="h-4 w-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.005 4.15H5.059z"
              ></path>
            </svg>
            <span class="sr-only">X (Twitter)</span>
          </a>
        </div>
      </div>

      <!-- Availability Card -->
      <div
        class="rounded-2xl border border-slate-200 bg-white/80 p-6 shadow-xl shadow-slate-200/20 backdrop-blur-sm dark:border-slate-800 dark:bg-slate-900/80 dark:shadow-none"
      >
        <div class="mb-3 flex items-center gap-3">
          <span class="relative flex h-3 w-3">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex h-3 w-3 rounded-full bg-emerald-500"
            ></span>
          </span>
          <span class="font-medium">Open to collaborations</span>
        </div>
        <p class="text-muted-foreground text-sm">
          I'm always interested in new projects and collaborations. Let's
          discuss how we can work together.
        </p>
      </div>
    </div>

    <!-- Contact Form Section -->
    <form
      action="https://api.web3forms.com/submit"
      id="contact-form"
      method="POST"
      class="space-y-6 rounded-2xl border border-slate-200 bg-white/80 p-8 shadow-xl shadow-slate-200/20 backdrop-blur-sm sm:p-10 lg:col-span-3 dark:border-slate-800 dark:bg-slate-900/80 dark:shadow-none"
    >
      <!-- Web3Forms Access Key -->
      <input
        type="hidden"
        name="access_key"
        value="747cf72a-0c4e-4ca2-9962-e0388b60cdf4"
      />
      <input
        type="checkbox"
        name="botcheck"
        class="hidden"
        style="display: none;"
      />

      <div>
        <label
          for="name"
          class="mb-2 block text-sm font-semibold text-slate-900 dark:text-white"
        >
          Name
        </label>
        <input
          type="text"
          name="name"
          id="name"
          required
          class="w-full rounded-md border border-slate-300 bg-white px-4 py-3 text-slate-900 transition-all outline-none placeholder:text-slate-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
          placeholder="John Doe"
        />
      </div>

      <div>
        <label
          for="email"
          class="mb-2 block text-sm font-semibold text-slate-900 dark:text-white"
        >
          Email
        </label>
        <input
          type="email"
          name="email"
          id="email"
          required
          class="w-full rounded-md border border-slate-300 bg-white px-4 py-3 text-slate-900 transition-all outline-none placeholder:text-slate-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
          placeholder="john@example.com"
        />
      </div>

      <div>
        <label
          for="message"
          class="mb-2 block text-sm font-semibold text-slate-900 dark:text-white"
        >
          Message
        </label>
        <textarea
          name="message"
          id="message"
          rows="5"
          required
          class="w-full resize-none rounded-md border border-slate-300 bg-white px-4 py-3 text-slate-900 transition-all outline-none placeholder:text-slate-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
          placeholder="How can I help you?"></textarea>
      </div>

      <button
        type="submit"
        class="w-full cursor-pointer rounded-md bg-indigo-600 py-4 font-bold text-white shadow-lg shadow-indigo-500/30 transition-all hover:bg-indigo-700 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:outline-none active:scale-[0.98]"
      >
        <span class="inline-flex items-center gap-4">
          <Send className="h-5 w-5" />
          Send Message
        </span>
      </button>
    </form>
    <div id="result" class="mt-3 text-center"></div>
  </div>
</section>

<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #dc3545;
  }
</style>

<script is:inline>
  document.addEventListener(
    "DOMContentLoaded",
    () => {
      const form = document.getElementById("contact-form");
      const result = document.getElementById("result");

      form.addEventListener("submit", function (e) {
        e.preventDefault();
        form.classList.add("was-validated");
        if (!form.checkValidity()) {
          form.querySelectorAll(":invalid")[0].focus();
          return;
        }
        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        result.innerHTML = "Sending...";

        fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: json,
        })
          .then(async (response) => {
            let json = await response.json();
            if (response.status == 200) {
              result.classList.add("text-green-500");
              result.innerHTML = json.message;
            } else {
              console.log(response);
              result.classList.add("text-red-500");
              result.innerHTML = json.message;
            }
          })
          .catch((error) => {
            console.log(error);
            result.innerHTML = "Something went wrong!";
          })
          .then(function () {
            form.reset();
            form.classList.remove("was-validated");
            setTimeout(() => {
              result.style.display = "none";
            }, 5000);
          });
      });
    },
    { once: true },
  );
</script>
