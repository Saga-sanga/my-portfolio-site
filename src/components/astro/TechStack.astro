---
import {
  Box,
  Code2,
  Database,
  FileCode,
  GitBranch,
  Layers,
  Layout,
  Server,
} from "lucide-react";
---

<div class="mt-16 border-t border-slate-200 pt-16 dark:border-slate-800">
  <p class="mb-8 text-center text-sm text-slate-600 dark:text-slate-400">
    My go-to tech stack for building modern applications
  </p>
  <div class="flex flex-wrap justify-center gap-8">
    {
      [
        { icon: Code2, name: "TypeScript" },
        { icon: Box, name: "React" },
        { icon: Layers, name: "SolidJS" },
        { icon: Layout, name: "Next.js" },
        { icon: Server, name: "Node.js" },
        { icon: Database, name: "PostgreSQL" },
        { icon: GitBranch, name: "Git" },
        { icon: FileCode, name: "Payload" },
      ].map((tech) => (
        <div class="group flex flex-col items-center gap-2">
          <div class="bg-card group-hover:border-primary/30 group-hover:bg-primary/5 flex h-14 w-14 items-center justify-center rounded-xl border border-slate-200 transition-all dark:border-slate-800">
            <tech.icon className="text-slate-600 dark:text-slate-400 group-hover:text-primary h-6 w-6 transition-colors" />
          </div>
          <span class="text-muted-foreground text-xs">{tech.name}</span>
        </div>
      ))
    }
  </div>
</div>
