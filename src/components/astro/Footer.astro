---
import { ArrowUp, Terminal } from "lucide-react";

const today = new Date();
---

<script>
  const button = document.querySelector("#scroll-button");

  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  button?.addEventListener("click", scrollToTop);
</script>

<footer
  class="mt-24 w-full border-t border-slate-200 bg-white/50 dark:border-slate-800 dark:bg-slate-950/50"
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-12 grid grid-cols-1 items-start gap-8 md:grid-cols-3">
      <!-- Brand & Tagline -->
      <div class="space-y-4 md:col-span-2">
        <a
          href="/"
          class="group flex items-center gap-2 text-xl font-bold tracking-tight text-slate-900 transition-colors hover:text-indigo-600 dark:text-white dark:hover:text-indigo-400"
        >
          <div
            class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-600 text-white transition-colors group-hover:bg-indigo-700"
          >
            <Terminal className="h-5 w-5" />
          </div>
          <span>Reckson Khiangte</span>
        </a>
        <p class="mb-6 max-w-sm text-slate-600 dark:text-slate-400">
          Building fast, accessible, and beautiful digital experiences. Always
          exploring new web technologies and design trends.
        </p>
        <button
          id="scroll-button"
          class="hover:text-primary inline-flex cursor-pointer items-center gap-2 text-sm text-slate-600 dark:text-slate-400"
        >
          <ArrowUp className="h-4 w-4" />
          Back to top
        </button>
      </div>

      <!-- Quick Links -->
      <div class="space-y-4">
        <h3 class="font-bold text-slate-900 dark:text-white">Navigation</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="/"
              class="text-slate-600 transition-colors hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400"
              >Home</a
            >
          </li>
          <li>
            <a
              href="/#about"
              class="text-slate-600 transition-colors hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400"
              >About</a
            >
          </li>
          <li>
            <a
              href="/projects"
              class="text-slate-600 transition-colors hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400"
              >Projects</a
            >
          </li>
          <li>
            <a
              href="/blog"
              class="text-slate-600 transition-colors hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400"
              >Blog</a
            >
          </li>
          <li>
            <a
              href="/#contact"
              class="text-slate-600 transition-colors hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400"
              >Contact</a
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="mb-8 h-px w-full bg-slate-200 dark:bg-slate-800"></div>

    <!-- Bottom Section -->
    <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
      <p class="text-sm text-slate-500 dark:text-slate-400">
        &copy; {today.getFullYear()} Reckson Khiangte. All rights reserved.
      </p>

      <div class="flex items-center gap-4 text-slate-500 dark:text-slate-400">
        <a
          href="https://github.com/Saga-sanga"
          target="_blank"
          rel="noreferrer"
          class="transition-colors hover:text-slate-900 dark:hover:text-white"
        >
          <svg
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
          <span class="sr-only">GitHub</span>
        </a>
        <a
          href="https://linkedin.com"
          target="_blank"
          rel="noreferrer"
          class="transition-colors hover:text-slate-900 dark:hover:text-white"
        >
          <svg
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              clip-rule="evenodd"></path>
          </svg>
          <span class="sr-only">LinkedIn</span>
        </a>
        <a
          href="https://twitter.com/RecksonKhiangte"
          target="_blank"
          rel="noreferrer"
          class="transition-colors hover:text-slate-900 dark:hover:text-white"
        >
          <svg
            class="h-4 w-4"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.005 4.15H5.059z"
            ></path>
          </svg>
          <span class="sr-only">X (Twitter)</span>
        </a>
      </div>
    </div>
  </div>
</footer>
